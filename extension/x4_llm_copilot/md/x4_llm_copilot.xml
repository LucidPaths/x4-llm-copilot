<?xml version="1.0" encoding="utf-8"?>
<mdscript name="X4LLMCopilot"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:noNamespaceSchemaLocation="md.xsd">
  <cues>
    <cue name="Root" instantiate="true">
      <conditions>
        <event_game_started />
      </conditions>
      <actions>
        <debug_text text="'X4 LLM Copilot loaded. Pipe name: x4_llm_copilot'" filter="general" />
      </actions>
      <cues>
        <cue name="PipeCheck" instantiate="true">
          <conditions>
            <event_cue_signalled cue="md.Named_Pipes.Reloaded" />
          </conditions>
          <actions>
            <signal_cue_instantly cue="md.Named_Pipes.Check" param="table[$pipe='x4_llm_copilot', $cue=PipeCheckCallback, $time=5s]" />
          </actions>
        </cue>
        <cue name="PipeCheckCallback" instantiate="true">
          <conditions>
            <event_cue_signalled />
          </conditions>
          <actions>
            <debug_text text="'X4 LLM Copilot pipe check: %s'.[event.param]" filter="general" />
          </actions>
        </cue>
      </cues>
    </cue>
  </cues>
</mdscript>
