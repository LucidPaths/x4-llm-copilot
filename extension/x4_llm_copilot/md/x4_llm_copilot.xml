<?xml version="1.0" encoding="utf-8"?>
<mdscript name="X4LLMCopilot"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:noNamespaceSchemaLocation="md.xsd">
  <cues>
    <cue name="Root" instantiate="true">
      <conditions>
        <event_game_started />
      </conditions>
      <actions>
        <debug_text text="'X4 LLM Copilot loaded. Waiting for Named Pipes API before ping smoke.'" filter="general" />
      </actions>
    </cue>

    <cue name="Pipe_API_Reloaded" instantiate="true">
      <conditions>
        <event_cue_signalled cue="md.Named_Pipes.Reloaded" />
      </conditions>
      <actions>
        <debug_text text="'X4 LLM Copilot: Named Pipes API reloaded; starting request read loop.'" filter="general" />
        <signal_cue_instantly cue="Start_Request_Read" />
      </actions>
    </cue>

    <cue name="Register_Chat_Command" instantiate="true">
      <conditions>
        <event_cue_signalled cue="md.Chat_Window_API.Reloaded" />
      </conditions>
      <actions>
        <signal_cue_instantly cue="md.Chat_Window_API.Register_Command" param="table[
          $name='hermes',
          $callback=Hermes_Chat_Command,
          $echo=table[]]" />
        <signal_cue_instantly cue="md.Chat_Window_API.Print" param="'Hermes cockpit chat ready. Use /hermes &lt;question&gt; in the X4 chat window.'" />
      </actions>
    </cue>

    <cue name="Hermes_Chat_Command" instantiate="true">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <raise_lua_event name="'x4LLMCopilotChatCommand'" param="event.param.$terms" />
      </actions>
    </cue>


    <cue name="Start_Request_Read" instantiate="true">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <debug_text text="'X4 LLM Copilot: starting request read loop.'" filter="general" />
        <signal_cue_instantly cue="md.Named_Pipes.Read" param="table[
          $pipe='x4_llm_copilot',
          $cue=Request_Read_Callback,
          $time=3600s,
          $cancel_on_timeout=true]" />
      </actions>
    </cue>

    <cue name="Request_Read_Callback" instantiate="true">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <debug_text text="'X4 LLM Copilot: request read result: %s'.[event.param]" filter="general" />
        <do_if value="event.param == 'ERROR' or event.param == 'TIMEOUT' or event.param == 'CANCELLED'">
          <debug_text text="'X4 LLM Copilot: request read failed; retrying after delay: %s'.[event.param]" filter="general" />
          <signal_cue_instantly cue="Delayed_Start_Request_Read" />
        </do_if>
        <do_else>
          <raise_lua_event name="'x4LLMCopilotFetchAmbient'" param="event.param" />
        </do_else>
      </actions>
    </cue>

    <cue name="Delayed_Start_Request_Read" instantiate="true">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <delay exact="2s" />
      <actions>
        <signal_cue_instantly cue="Start_Request_Read" />
      </actions>
    </cue>

    <cue name="Ambient_Raw_From_Lua" instantiate="true">
      <conditions>
        <event_ui_triggered screen="'X4LLMCopilot'" control="'AmbientRaw'" />
      </conditions>
      <actions>
        <debug_text text="'X4 LLM Copilot: raw ambient from Lua: %s'.[event.param3]" filter="general" />
        <signal_cue_instantly cue="md.Named_Pipes.Write" param="table[
          $pipe='x4_llm_copilot',
          $msg=event.param3,
          $cue=Ambient_Write_Callback,
          $time=5s]" />
      </actions>
    </cue>

    <cue name="Chat_Request_From_Lua" instantiate="true">
      <conditions>
        <event_ui_triggered screen="'X4LLMCopilot'" control="'ChatRequest'" />
      </conditions>
      <actions>
        <debug_text text="'X4 LLM Copilot: chat request from Lua: %s'.[event.param3]" filter="general" />
        <signal_cue_instantly cue="md.Named_Pipes.Write" param="table[
          $pipe='x4_llm_copilot',
          $msg=event.param3,
          $cue=Chat_Write_Callback,
          $time=5s]" />
      </actions>
    </cue>

    <cue name="Chat_Write_Callback" instantiate="true">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <debug_text text="'X4 LLM Copilot: chat write result: %s'.[event.param]" filter="general" />
        <do_if value="event.param != 'SUCCESS'">
          <signal_cue_instantly cue="md.Chat_Window_API.Print" param="'Hermes chat error: pipe write failed: %s'.[event.param]" />
        </do_if>
      </actions>
    </cue>

    <cue name="Chat_Print_From_Lua" instantiate="true">
      <conditions>
        <event_ui_triggered screen="'X4LLMCopilot'" control="'ChatPrint'" />
      </conditions>
      <actions>
        <signal_cue_instantly cue="md.Chat_Window_API.Print" param="event.param3" />
      </actions>
    </cue>

    <cue name="Chat_Pending_From_Lua" instantiate="true">
      <conditions>
        <event_ui_triggered screen="'X4LLMCopilot'" control="'ChatPending'" />
      </conditions>
      <delay exact="90s" />
      <actions>
        <raise_lua_event name="'x4LLMCopilotChatTimeout'" param="event.param3" />
      </actions>
    </cue>

    <cue name="Ambient_Write_Callback" instantiate="true">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <debug_text text="'X4 LLM Copilot: ambient write result: %s'.[event.param]" filter="general" />
        <do_if value="event.param == 'SUCCESS'">
          <signal_cue_instantly cue="md.Named_Pipes.Read" param="table[
            $pipe='x4_llm_copilot',
            $cue=Ambient_Read_Callback,
            $time=5s,
            $cancel_on_timeout=true]" />
        </do_if>
      </actions>
    </cue>

    <cue name="Ambient_Read_Callback" instantiate="true">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <debug_text text="'X4 LLM Copilot: ambient read result: %s'.[event.param]" filter="general" />
        <signal_cue_instantly cue="Start_Request_Read" />
      </actions>
    </cue>

    <cue name="Pipe_API_Disabled" instantiate="true">
      <conditions>
        <event_ui_triggered screen="'Named_Pipes'" control="'disabled'" />
      </conditions>
      <actions>
        <debug_text text="'X4 LLM Copilot: Named Pipes API disabled; Protected UI mode or DLL load is still blocking telemetry.'" filter="general" />
      </actions>
    </cue>
  </cues>
</mdscript>
